# Ignore Python bytecode caches.
__pycache__/
# Ignore compiled Python bytecode files.
*.py[cod]
# Ignore compiled native extensions built on local machines.
*.pyd
# Ignore Python build artifacts.
build/
# Ignore Python distribution artifacts.
dist/
# Ignore Python package metadata generated by local installs.
*.egg-info/

# Ignore generated annotation outputs.
outputs/
# Ignore legacy generated output folders.
output/
# Ignore local input scratch folders.
input/
# Ignore generated zip downloads.
*.zip

# Ignore large model checkpoints that should be downloaded separately.
weights/*.pth
# Ignore PyTorch checkpoint variants that should not be committed.
weights/*.pt
# Ignore ONNX model exports that should not be committed.
weights/*.onnx

# Keep the weights folder documentation in git.
!weights/README.md
